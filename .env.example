POSTGRES_IMAGE=postgres:16.4
POSTGRES_DB=aegis
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegis_dev_password
POSTGRES_PORT=5432

REDIS_IMAGE=redis:7.4-alpine
NATS_IMAGE=nats:2.10-alpine
OPA_IMAGE=openpolicyagent/opa:0.70.0
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:26.0
OPENBAO_IMAGE=openbao/openbao:2.0.0
OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:0.116.1
PROMETHEUS_IMAGE=prom/prometheus:v2.55.1
GRAFANA_IMAGE=grafana/grafana:11.4.0

AEGIS_PORT=8080
AEGIS_SERVICE_NAME=aegis-gateway
AEGIS_ENVIRONMENT=development
AEGIS_HTTP_ADDR=:8080
AEGIS_DATABASE_URL=postgres://aegis:aegis_dev_password@localhost:5432/aegis?sslmode=disable
AEGIS_REQUIRE_DATABASE=true
AEGIS_OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
AEGIS_LOG_LEVEL=info

AEGIS_AUTH_ENABLED=false
AEGIS_AUTH_ISSUER=http://localhost:8081/realms/aegis
AEGIS_AUTH_AUDIENCE=aegis-gateway
AEGIS_AUTH_JWKS_URL=http://localhost:8081/realms/aegis/protocol/openid-connect/certs
AEGIS_AUTH_REQUIRED_SCOPES=aegis.invoke
AEGIS_AUTH_APPROVED_ALGORITHMS=RS256
AEGIS_AUTH_REQUIRED_TOKEN_TYPE=Bearer
AEGIS_AUTH_CLOCK_SKEW=30s
AEGIS_AUTH_PROTECTED_RESOURCE_ID=http://localhost:8080

AEGIS_OPA_URL=http://localhost:8181
AEGIS_OPA_DECISION_PATH=aegis/authz/decision
AEGIS_OPA_POLICY_VERSION=local-bundle
AEGIS_OPA_TIMEOUT=2s
AEGIS_OPENBAO_ADDR=http://localhost:8200
AEGIS_OPENBAO_TOKEN=dev-root-token
AEGIS_OPENBAO_MOUNT=secret
AEGIS_NATS_ADDR=localhost:4222
AEGIS_NATS_SUBJECT=aegis.events
AEGIS_REDIS_ADDR=localhost:6379
AEGIS_REDIS_PREFIX=aegis:ratelimit:
AEGIS_WORKER_OUTBOX_INTERVAL=2s
AEGIS_WORKER_OUTBOX_BATCH_SIZE=50
AEGIS_WORKER_OUTBOX_MAX_ATTEMPTS=5
AEGIS_WORKER_APPROVAL_EXPIRY_INTERVAL=30s
AEGIS_WORKER_BUDGET_SWEEP_INTERVAL=30s
AEGIS_WORKER_BUDGET_RESERVATION_TTL=15m
AEGIS_WORKER_BUDGET_SWEEP_BATCH_SIZE=50
AEGIS_WORKER_RECONCILIATION_INTERVAL=30s
AEGIS_WORKER_RECONCILIATION_BATCH_SIZE=25
AEGIS_WORKER_RECONCILIATION_LEASE_DURATION=2m
AEGIS_WORKER_RECONCILIATION_RETRY_AFTER=1m
AEGIS_WORKER_RECONCILIATION_LEASE_OWNER=aegis-worker
AEGIS_WORKER_POLICY_SIMULATION_INTERVAL=60s
AEGIS_WORKER_POLICY_SIMULATION_BATCH_SIZE=10
AEGIS_WORKER_POLICY_SIMULATION_LEASE_DURATION=5m
AEGIS_WORKER_POLICY_SIMULATION_RETRY_AFTER=5m
AEGIS_WORKER_POLICY_SIMULATION_LEASE_OWNER=aegis-worker
AEGIS_WORKER_AUDIT_ROOT_INTERVAL=60s
AEGIS_WORKER_AUDIT_ROOT_SIGNER=aegis-dev-signer

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
OPENBAO_DEV_TOKEN=dev-root-token
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

PAYMENTS_MCP_PORT=8091
CRM_MCP_PORT=8092
MESSAGING_MCP_PORT=8093
